# Auto-detect text files and normalize line endings
* text=auto

# Explicitly set scripts and source files to LF in the repo
*.py text eol=lf
*.jsx text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
